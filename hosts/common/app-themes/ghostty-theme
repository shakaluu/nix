# Berni — Ghostty color scheme
# Based on the Abernathy theme (bundled with Ghostty).
# ANSI slot roles for the berni zsh-theme prompt:
#   black   → status segment background
#   red     → git modified/deleted bg
#   green   → git clean bg
#   yellow  → git dirty bg (black fg)
#   blue    → kube-ps1 segment bg, time segment bg
#   magenta → SSH context bg
#   cyan    → directory segment bg
#   white   → text on all coloured segments

background           = #111416
foreground           = #eeeeec
cursor-color         = #bbbbbb
cursor-text          = #ffffff
selection-background = #eeeeec
selection-foreground = #333333

# Normal (0-7) — Abernathy
palette = 0=#000000
palette = 1=#cd0000
palette = 2=#00cd00
palette = 3=#cdcd00
palette = 4=#1093f5
palette = 5=#cd00cd
palette = 6=#00cdcd
palette = 7=#faebd7

# Bright (8-15) — Abernathy
palette = 8=#404040
palette = 9=#ff0000
palette = 10=#00ff00
palette = 11=#ffff00
palette = 12=#11b5f6
palette = 13=#ff00ff
palette = 14=#00ffff
palette = 15=#ffffff
